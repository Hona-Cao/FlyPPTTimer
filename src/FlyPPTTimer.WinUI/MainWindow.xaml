<Window
    x:Class="FlyPPTTimer.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="FlyPPTTimer">
    <Window.SystemBackdrop><MicaBackdrop /></Window.SystemBackdrop>
    <Grid x:Name="Root">
        <Grid.RowDefinitions><RowDefinition Height="48" /><RowDefinition Height="*" /></Grid.RowDefinitions>
        <Grid x:Name="AppTitleBar" Height="48" Padding="8,0" ColumnSpacing="10">
            <Grid.ColumnDefinitions><ColumnDefinition Width="40" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
            <Button Width="36" Height="36" Padding="0" Click="PaneButton_Click" ToolTipService.ToolTip="展开导航"><FontIcon Glyph="&#xE700;" /></Button>
            <TextBlock Grid.Column="1" Text="FlyPPTTimer" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" />
            <TextBlock Grid.Column="2" Text="演讲计时与 PowerPoint 遥控" Margin="8,0,0,0" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
        </Grid>
        <NavigationView x:Name="NavView" Grid.Row="1" IsBackButtonVisible="Collapsed" IsPaneToggleButtonVisible="False" PaneDisplayMode="Auto" OpenPaneLength="220" SelectionChanged="NavView_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem Content="概览" Tag="overview" IsSelected="True" />
                <NavigationViewItem Content="计时" Tag="timer" />
                <NavigationViewItem Content="PowerPoint" Tag="powerpoint" />
                <NavigationViewItem Content="文件与规则" Tag="files" />
                <NavigationViewItem Content="手机遥控" Tag="remote" />
                <NavigationViewItem Content="外观与显示" Tag="appearance" />
                <NavigationViewItem Content="快捷键" Tag="hotkeys" />
                <NavigationViewItem Content="设置" Tag="settings" />
                <NavigationViewItem Content="日志与诊断" Tag="diagnostics" />
            </NavigationView.MenuItems>
            <Frame x:Name="NavFrame" />
        </NavigationView>
    </Grid>
</Window>
