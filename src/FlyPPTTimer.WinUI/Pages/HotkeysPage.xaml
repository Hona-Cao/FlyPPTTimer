<Page x:Class="FlyPPTTimer.WinUI.Pages.HotkeysPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer><StackPanel Padding="32" Spacing="20" MaxWidth="820"><StackPanel><TextBlock Text="快捷键" Style="{StaticResource PageTitleStyle}" /><TextBlock Text="设置全局快捷键；留空可禁用对应动作" Style="{StaticResource CaptionStyle}" /></StackPanel><Border Style="{StaticResource CardStyle}"><Grid ColumnSpacing="20" RowSpacing="12"><Grid.ColumnDefinitions><ColumnDefinition Width="220" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions><TextBlock Text="开始 / 暂停" /><TextBox x:Name="StartPause" Grid.Column="1" /><TextBlock Grid.Row="1" Text="停止 / 重置" /><TextBox x:Name="StopReset" Grid.Row="1" Grid.Column="1" /><TextBlock Grid.Row="2" Text="显示 / 隐藏窗口" /><TextBox x:Name="ToggleWindow" Grid.Row="2" Grid.Column="1" /><TextBlock Grid.Row="3" Text="打开设置" /><TextBox x:Name="OpenSettings" Grid.Row="3" Grid.Column="1" /><TextBlock Grid.Row="4" Text="触发闪烁" /><TextBox x:Name="Flash" Grid.Row="4" Grid.Column="1" /><TextBlock Grid.Row="5" Text="静音切换" /><TextBox x:Name="Mute" Grid.Row="5" Grid.Column="1" /></Grid></Border><InfoBar IsOpen="True" Severity="Informational" Message="快捷键由 Windows 注册；与其他软件冲突时会在日志中说明。" /><Button Content="保存快捷键" HorizontalAlignment="Right" Click="Apply_Click" /></StackPanel></ScrollViewer>
</Page>
