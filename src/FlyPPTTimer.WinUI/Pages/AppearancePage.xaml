<Page x:Class="FlyPPTTimer.WinUI.Pages.AppearancePage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer><StackPanel Padding="32" Spacing="20" MaxWidth="900">
        <StackPanel><TextBlock Text="外观与显示" Style="{StaticResource PageTitleStyle}" /><TextBlock Text="主题、悬浮计时窗口和多屏位置" Style="{StaticResource CaptionStyle}" /></StackPanel>
        <Border Style="{StaticResource CardStyle}"><Grid ColumnSpacing="20" RowSpacing="14"><Grid.ColumnDefinitions><ColumnDefinition Width="220" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
            <TextBlock Text="应用主题" VerticalAlignment="Center" /><ComboBox x:Name="ThemeBox" Grid.Column="1"><ComboBoxItem Content="跟随系统" /><ComboBoxItem Content="浅色" /><ComboBoxItem Content="深色" /></ComboBox>
            <TextBlock Grid.Row="1" Text="使用 Mica 材质" /><ToggleSwitch x:Name="MicaSwitch" Grid.Row="1" Grid.Column="1" />
            <TextBlock Grid.Row="2" Text="减少动画" /><ToggleSwitch x:Name="MotionSwitch" Grid.Row="2" Grid.Column="1" />
            <TextBlock Grid.Row="3" Text="显示在所有屏幕" /><ToggleSwitch x:Name="AllScreensSwitch" Grid.Row="3" Grid.Column="1" />
        </Grid></Border>
        <Border Style="{StaticResource CardStyle}"><Grid ColumnSpacing="20" RowSpacing="14"><Grid.ColumnDefinitions><ColumnDefinition Width="220" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
            <TextBlock Text="窗口宽度" /><NumberBox x:Name="WidthBox" Grid.Column="1" Minimum="120" Maximum="1200" />
            <TextBlock Grid.Row="1" Text="窗口高度" /><NumberBox x:Name="HeightBox" Grid.Row="1" Grid.Column="1" Minimum="40" Maximum="500" />
            <TextBlock Grid.Row="2" Text="字体" /><TextBox x:Name="FontFamilyBox" Grid.Row="2" Grid.Column="1" />
            <TextBlock Grid.Row="3" Text="字号" /><NumberBox x:Name="FontBox" Grid.Row="3" Grid.Column="1" Minimum="12" Maximum="180" />
            <TextBlock Grid.Row="4" Text="背景透明度" /><Slider x:Name="BackgroundOpacity" Grid.Row="4" Grid.Column="1" Minimum="0" Maximum="100" />
            <TextBlock Grid.Row="5" Text="文字透明度" /><Slider x:Name="TextOpacity" Grid.Row="5" Grid.Column="1" Minimum="20" Maximum="100" />
        </Grid></Border>
        <Border Style="{StaticResource CardStyle}"><Grid ColumnSpacing="20" RowSpacing="14"><Grid.ColumnDefinitions><ColumnDefinition Width="220" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
            <TextBlock Text="文字颜色" /><TextBox x:Name="TextColorBox" Grid.Column="1" PlaceholderText="#FFFFFF" />
            <TextBlock Grid.Row="1" Text="背景颜色" /><TextBox x:Name="BackgroundColorBox" Grid.Row="1" Grid.Column="1" PlaceholderText="#202733" />
            <TextBlock Grid.Row="2" Text="闪烁颜色" /><TextBox x:Name="FlashColorBox" Grid.Row="2" Grid.Column="1" PlaceholderText="#FFC107" />
            <TextBlock Grid.Row="3" Text="始终置顶" /><ToggleSwitch x:Name="AlwaysOnTopSwitch" Grid.Row="3" Grid.Column="1" />
        </Grid></Border>
        <Border Style="{StaticResource CardStyle}"><Grid ColumnSpacing="20" RowSpacing="14"><Grid.ColumnDefinitions><ColumnDefinition Width="220" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
            <TextBlock Text="显示计时窗口" /><ToggleSwitch x:Name="VisibleSwitch" Grid.Column="1" />
            <TextBlock Grid.Row="1" Text="默认位置" /><ComboBox x:Name="AnchorBox" Grid.Row="1" Grid.Column="1"><ComboBoxItem Content="左上" /><ComboBoxItem Content="上中" /><ComboBoxItem Content="右上" /><ComboBoxItem Content="左中" /><ComboBoxItem Content="居中" /><ComboBoxItem Content="右中" /><ComboBoxItem Content="左下" /><ComboBoxItem Content="下中" /><ComboBoxItem Content="右下" /></ComboBox>
            <TextBlock Grid.Row="2" Text="水平微调（%）" /><NumberBox x:Name="OffsetXBox" Grid.Row="2" Grid.Column="1" Minimum="-100" Maximum="100" SmallChange="0.1" />
            <TextBlock Grid.Row="3" Text="垂直微调（%）" /><NumberBox x:Name="OffsetYBox" Grid.Row="3" Grid.Column="1" Minimum="-100" Maximum="100" SmallChange="0.1" />
        </Grid></Border>
        <InfoBar x:Name="ValidationBar" IsOpen="False" /><Button Content="应用外观" Style="{StaticResource AccentButtonStyle}" HorizontalAlignment="Right" Click="Apply_Click" />
    </StackPanel></ScrollViewer>
</Page>
