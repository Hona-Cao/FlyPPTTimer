<Page x:Class="FlyPPTTimer.WinUI.Pages.RemotePage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer><StackPanel Padding="32" Spacing="20" MaxWidth="960">
        <StackPanel><TextBlock Text="手机遥控" Style="{StaticResource PageTitleStyle}" /><TextBlock Text="计时和演示控制共用一个端口、令牌与二维码" Style="{StaticResource CaptionStyle}" /></StackPanel>
        <Border Style="{StaticResource CardStyle}"><Grid ColumnSpacing="16"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><StackPanel Spacing="6"><TextBlock Text="{Binding RemoteStatus}" FontSize="20" FontWeight="SemiBold" /><TextBlock Text="同一局域网内可连接；Clash/TUN 请将局域网地址设为 DIRECT" Style="{StaticResource CaptionStyle}" /></StackPanel><StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"><Button Content="重启服务" Click="Restart_Click" /><Button Content="断开所有设备" Click="Disconnect_Click" /></StackPanel></Grid></Border>
        <Border Style="{StaticResource CardStyle}"><Grid ColumnSpacing="28"><Grid.ColumnDefinitions><ColumnDefinition Width="280" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><Border Background="White" CornerRadius="8" Padding="14"><Image x:Name="QrImage" Width="252" Height="252" /></Border><StackPanel Grid.Column="1" Spacing="12" VerticalAlignment="Center"><TextBlock Text="扫码连接" Style="{StaticResource SectionTitleStyle}" /><TextBlock Text="选择本机地址" Style="{StaticResource CaptionStyle}" /><ComboBox x:Name="AddressBox" SelectionChanged="Address_Changed" /><TextBlock Text="访问链接" Style="{StaticResource CaptionStyle}" /><TextBox x:Name="UrlBox" Text="{Binding RemoteUrl}" IsReadOnly="True" TextWrapping="Wrap" /><Button Content="复制链接" Click="Copy_Click" /><Button Content="在本机浏览器打开" Click="Open_Click" /></StackPanel></Grid></Border>
        <Border Style="{StaticResource CardStyle}"><StackPanel Spacing="8"><TextBlock Text="防火墙提示" Style="{StaticResource SectionTitleStyle}" /><TextBlock Text="若手机无法访问，请允许 FlyPPTTimer 通过 Windows 防火墙。程序不会自动执行系统命令。" Style="{StaticResource CaptionStyle}" /><Button Content="复制放行命令" HorizontalAlignment="Left" Click="Firewall_Click" /></StackPanel></Border>
    </StackPanel></ScrollViewer>
</Page>
