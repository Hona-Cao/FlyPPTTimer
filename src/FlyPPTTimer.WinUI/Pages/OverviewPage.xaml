<Page x:Class="FlyPPTTimer.WinUI.Pages.OverviewPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer><StackPanel Padding="32" Spacing="20" MaxWidth="1120" HorizontalAlignment="Stretch">
        <StackPanel><TextBlock Text="概览" Style="{StaticResource PageTitleStyle}" /><TextBlock Text="计时、演示和手机连接的实时状态" Style="{StaticResource CaptionStyle}" /></StackPanel>
        <Grid ColumnSpacing="16" RowSpacing="16"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
            <Border Style="{StaticResource CardStyle}"><StackPanel Spacing="12"><TextBlock Text="当前计时" Style="{StaticResource SectionTitleStyle}" /><TextBlock Text="{Binding TimerDisplay}" FontFamily="Cascadia Mono" FontSize="52" FontWeight="SemiBold" /><TextBlock Text="{Binding TimerStatus}" /></StackPanel></Border>
            <Border Grid.Column="1" Style="{StaticResource CardStyle}"><StackPanel Spacing="10"><TextBlock Text="当前演示" Style="{StaticResource SectionTitleStyle}" /><TextBlock Text="{Binding PresentationName}" FontSize="20" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" /><TextBlock Text="{Binding SlideText}" /><TextBlock Text="{Binding PresentationStatus}" Style="{StaticResource CaptionStyle}" /></StackPanel></Border>
            <Border Grid.Row="1" Style="{StaticResource CardStyle}"><StackPanel Spacing="12"><TextBlock Text="快速控制" Style="{StaticResource SectionTitleStyle}" /><StackPanel Orientation="Horizontal" Spacing="8"><Button Content="开始" Command="{Binding StartTimerCommand}" /><Button Content="暂停" Command="{Binding PauseTimerCommand}" /><Button Content="停止" Command="{Binding StopTimerCommand}" /></StackPanel></StackPanel></Border>
            <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource CardStyle}"><StackPanel Spacing="8"><TextBlock Text="手机遥控" Style="{StaticResource SectionTitleStyle}" /><TextBlock Text="{Binding RemoteStatus}" /><TextBlock Text="{Binding RemoteUrl}" TextTrimming="CharacterEllipsis" Style="{StaticResource CaptionStyle}" /><InfoBar IsOpen="True" Severity="Informational" Message="{Binding LastMessage}" /></StackPanel></Border>
        </Grid>
    </StackPanel></ScrollViewer>
</Page>
