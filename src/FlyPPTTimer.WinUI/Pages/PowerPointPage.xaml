<Page x:Class="FlyPPTTimer.WinUI.Pages.PowerPointPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer><StackPanel Padding="32" Spacing="20" MaxWidth="1080">
        <StackPanel><TextBlock Text="PowerPoint" Style="{StaticResource PageTitleStyle}" /><TextBlock Text="状态读取与控制全部由专用 STA 服务完成" Style="{StaticResource CaptionStyle}" /></StackPanel>
        <Border Style="{StaticResource CardStyle}"><Grid ColumnSpacing="16"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><StackPanel Spacing="8"><TextBlock Text="{Binding PresentationName}" FontSize="22" FontWeight="SemiBold" /><TextBlock Text="{Binding PresentationPath}" TextWrapping="Wrap" Style="{StaticResource CaptionStyle}" /><StackPanel Orientation="Horizontal" Spacing="12"><TextBlock Text="{Binding PresentationStatus}" /><TextBlock Text="{Binding SlideText}" FontWeight="SemiBold" /><TextBlock Text="{Binding ScreenMode}" /></StackPanel></StackPanel><Button Grid.Column="1" Content="重启控制服务" Click="Restart_Click" /></Grid></Border>
        <Border Style="{StaticResource CardStyle}"><StackPanel Spacing="14"><TextBlock Text="放映控制" Style="{StaticResource SectionTitleStyle}" /><Grid ColumnSpacing="8" RowSpacing="8"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
            <Button Content="从头放映" Command="{Binding PptCommandCommand}" CommandParameter="ppt.startFromBeginning" /><Button Grid.Column="1" Content="从当前页放映" Command="{Binding PptCommandCommand}" CommandParameter="ppt.startFromCurrent" /><Button Grid.Column="2" Content="上一页" Command="{Binding PptCommandCommand}" CommandParameter="ppt.previous" /><Button Grid.Column="3" Content="下一页" Command="{Binding PptCommandCommand}" CommandParameter="ppt.next" />
            <Button Grid.Row="1" Content="黑屏 / 恢复" Command="{Binding PptCommandCommand}" CommandParameter="ppt.blackScreenToggle" /><Button Grid.Row="1" Grid.Column="1" Content="白屏 / 恢复" Command="{Binding PptCommandCommand}" CommandParameter="ppt.whiteScreenToggle" /><StackPanel Grid.Row="1" Grid.Column="2" Orientation="Horizontal" Spacing="6"><NumberBox x:Name="SlideBox" Width="100" Minimum="1" SpinButtonPlacementMode="Compact" /><Button Content="跳转" Click="Goto_Click" /></StackPanel><Button Grid.Row="1" Grid.Column="3" Content="结束放映" Click="EndShow_Click" />
        </Grid></StackPanel></Border>
        <Border Style="{StaticResource CardStyle}"><StackPanel Spacing="12"><TextBlock Text="可用演示文稿" Style="{StaticResource SectionTitleStyle}" /><ListView ItemsSource="{Binding Presentations}"><ListView.ItemTemplate><DataTemplate><Grid Padding="4" ColumnSpacing="12"><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><StackPanel><TextBlock Text="{Binding Name}" FontWeight="SemiBold" /><TextBlock Text="{Binding Directory}" TextTrimming="CharacterEllipsis" Style="{StaticResource CaptionStyle}" /></StackPanel><Button Grid.Column="1" Content="打开" Tag="{Binding Id}" Click="Open_Click" /></Grid></DataTemplate></ListView.ItemTemplate></ListView></StackPanel></Border>
    </StackPanel></ScrollViewer>
</Page>
