<Page x:Class="FlyPPTTimer.WinUI.Pages.TimerPage" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer><StackPanel Padding="32" Spacing="20" MaxWidth="960">
        <StackPanel><TextBlock Text="计时" Style="{StaticResource PageTitleStyle}" /><TextBlock Text="控制当前演讲计时和默认时长" Style="{StaticResource CaptionStyle}" /></StackPanel>
        <Border Style="{StaticResource CardStyle}" Background="{ThemeResource AccentCardBrush}"><StackPanel HorizontalAlignment="Center" Spacing="12"><TextBlock Text="{Binding TimerDisplay}" FontFamily="Cascadia Mono" FontSize="76" FontWeight="SemiBold" /><TextBlock Text="{Binding TimerStatus}" HorizontalAlignment="Center" FontSize="18" /><StackPanel Orientation="Horizontal" Spacing="8"><Button Content="开始" Command="{Binding StartTimerCommand}" /><Button Content="暂停" Command="{Binding PauseTimerCommand}" /><Button Content="继续" Command="{Binding ResumeTimerCommand}" /><Button Content="停止并重置" Command="{Binding StopTimerCommand}" /></StackPanel></StackPanel></Border>
        <Border Style="{StaticResource CardStyle}"><Grid ColumnSpacing="20" RowSpacing="14"><Grid.ColumnDefinitions><ColumnDefinition Width="220" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
            <TextBlock Text="默认时长" VerticalAlignment="Center" /><TextBox x:Name="DurationBox" Grid.Column="1" Text="{Binding Config.Timer.DefaultDuration}" PlaceholderText="HH:mm:ss" />
            <TextBlock Grid.Row="1" Text="计时方式" VerticalAlignment="Center" /><ComboBox x:Name="ModeBox" Grid.Row="1" Grid.Column="1" SelectedIndex="0"><ComboBoxItem Content="倒计时" /><ComboBoxItem Content="正计时" /></ComboBox>
            <TextBlock Grid.Row="2" Text="超时后继续计时" VerticalAlignment="Center" /><ToggleSwitch x:Name="OvertimeSwitch" Grid.Row="2" Grid.Column="1" IsOn="{Binding Config.Timer.ContinueOvertime}" />
        </Grid></Border>
        <Button Content="应用计时设置" HorizontalAlignment="Right" Click="Apply_Click" />
    </StackPanel></ScrollViewer>
</Page>
