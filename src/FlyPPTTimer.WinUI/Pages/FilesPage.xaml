<Page
    x:Class="FlyPPTTimer.WinUI.Pages.FilesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    AllowDrop="True"
    DragOver="Page_DragOver"
    Drop="Page_Drop">
    <Grid Padding="32" RowSpacing="16" ColumnSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.ColumnSpan="2">
            <TextBlock Text="文件与规则" Style="{StaticResource PageTitleStyle}" />
            <TextBlock Text="添加多个 PPT，设置独立时长并同步到手机遥控" Style="{StaticResource CaptionStyle}" />
        </StackPanel>
        <CommandBar Grid.Row="1" Grid.ColumnSpan="2" DefaultLabelPosition="Right">
            <AppBarButton Icon="Add" Label="添加文件" Click="Add_Click" />
            <AppBarButton Icon="Delete" Label="删除所选" Click="Delete_Click" />
            <AppBarButton Icon="Clear" Label="清空" Click="ClearAll_Click" />
            <AppBarButton Icon="SelectAll" Label="全选" Click="SelectAll_Click" />
            <AppBarButton Icon="ClearSelection" Label="取消全选" Click="ClearSelection_Click" />
            <AppBarSeparator />
            <AppBarButton Icon="Upload" Label="置顶" Click="Top_Click" />
            <AppBarButton Icon="Up" Label="上移" Click="Up_Click" />
            <AppBarButton Icon="Down" Label="下移" Click="Down_Click" />
            <AppBarButton Icon="Download" Label="置底" Click="Bottom_Click" />
        </CommandBar>

        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="8">
            <ListView x:Name="RuleList" ItemsSource="{Binding Rules}" SelectedItem="{Binding SelectedRule,Mode=TwoWay}"
                      SelectionMode="Single" CanDragItems="True" CanReorderItems="True" ReorderMode="Enabled"
                      DragItemsCompleted="RuleList_DragItemsCompleted" SelectionChanged="RuleList_SelectionChanged">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="8" ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" /><ColumnDefinition Width="36" /><ColumnDefinition Width="*" />
                                <ColumnDefinition Width="110" /><ColumnDefinition Width="90" />
                            </Grid.ColumnDefinitions>
                            <CheckBox IsChecked="{Binding IsSelected,Mode=TwoWay}" VerticalAlignment="Center" />
                            <FontIcon Grid.Column="1" Glyph="&#xE8A5;" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                <TextBlock Text="{Binding FilePath}" TextTrimming="CharacterEllipsis" Style="{StaticResource CaptionStyle}" ToolTipService.ToolTip="{Binding FilePath}" />
                            </StackPanel>
                            <TextBox Grid.Column="3" Text="{Binding Duration,Mode=TwoWay}" LostFocus="Duration_LostFocus" />
                            <StackPanel Grid.Column="4">
                                <ToggleSwitch IsOn="{Binding Enabled,Mode=TwoWay}" Toggled="Enabled_Toggled" />
                                <TextBlock Text="{Binding Status}" FontSize="12" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>

        <Border Grid.Row="2" Grid.Column="1" Style="{StaticResource CardStyle}">
            <ScrollViewer>
                <StackPanel Spacing="14" DataContext="{Binding SelectedRule}">
                    <TextBlock Text="文件详情" Style="{StaticResource SectionTitleStyle}" />
                    <Border Height="160" CornerRadius="6" Background="{ThemeResource ControlFillColorDefaultBrush}">
                        <Grid>
                            <Image x:Name="ThumbnailImage" Stretch="Uniform" />
                            <TextBlock x:Name="ThumbnailPlaceholder" Text="首张幻灯片预览" HorizontalAlignment="Center" VerticalAlignment="Center" Style="{StaticResource CaptionStyle}" />
                        </Grid>
                    </Border>
                    <TextBlock Text="{Binding FileName}" FontSize="20" FontWeight="SemiBold" TextWrapping="Wrap" />
                    <TextBlock Text="{Binding FilePath}" TextWrapping="Wrap" Style="{StaticResource CaptionStyle}" />
                    <Grid ColumnSpacing="8" RowSpacing="8">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="110" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                        <TextBlock Text="文件大小" /><TextBlock Grid.Column="1" Text="{Binding FileSize}" />
                        <TextBlock Grid.Row="1" Text="修改时间" /><TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Modified}" />
                        <TextBlock Grid.Row="2" Text="状态" /><TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Status}" />
                        <TextBlock Grid.Row="3" Text="计时时长" /><TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Duration}" />
                        <TextBlock Grid.Row="4" Text="排序位置" /><TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Position}" />
                    </Grid>
                    <Button Content="打开文件" Click="Open_Click" /><Button Content="打开并从头放映" Click="OpenStart_Click" />
                    <Button Content="打开并从当前页放映" Click="OpenCurrent_Click" /><Button Content="在资源管理器中显示" Click="Explorer_Click" />
                    <Button Content="复制完整路径" Click="CopyPath_Click" /><Button Content="重新定位文件" Click="Relocate_Click" />
                    <TextBlock Text="批量时长" Style="{StaticResource SectionTitleStyle}" />
                    <StackPanel Orientation="Horizontal" Spacing="8"><TextBox x:Name="BatchDuration" PlaceholderText="HH:mm:ss" Width="150" /><Button Content="应用到所选" Click="BatchDuration_Click" /></StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>
        <InfoBar x:Name="MessageBar" Grid.Row="2" Grid.ColumnSpan="2" VerticalAlignment="Bottom" IsOpen="False" />
    </Grid>
</Page>
