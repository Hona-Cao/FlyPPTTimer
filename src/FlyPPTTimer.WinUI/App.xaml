<Application
    x:Class="FlyPPTTimer.WinUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <controls:XamlControlsResources />
            </ResourceDictionary.MergedDictionaries>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Default">
                    <SolidColorBrush x:Key="AccentCardBrush" Color="#E8F4F2" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="AccentCardBrush" Color="#173B38" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
            <Style TargetType="Button">
                <Setter Property="MinHeight" Value="40" />
                <Setter Property="CornerRadius" Value="6" />
                <Setter Property="Padding" Value="14,8" />
            </Style>
            <Style TargetType="TextBox"><Setter Property="MinHeight" Value="40" /><Setter Property="CornerRadius" Value="6" /></Style>
            <Style TargetType="ComboBox"><Setter Property="MinHeight" Value="40" /><Setter Property="CornerRadius" Value="6" /></Style>
            <Style x:Key="CardStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="20" />
            </Style>
            <Style x:Key="PageTitleStyle" TargetType="TextBlock"><Setter Property="FontSize" Value="28" /><Setter Property="FontWeight" Value="SemiBold" /></Style>
            <Style x:Key="SectionTitleStyle" TargetType="TextBlock"><Setter Property="FontSize" Value="17" /><Setter Property="FontWeight" Value="SemiBold" /></Style>
            <Style x:Key="CaptionStyle" TargetType="TextBlock"><Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" /><Setter Property="TextWrapping" Value="Wrap" /></Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
