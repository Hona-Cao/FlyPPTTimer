<Window
    x:Class="FlyPPTTimer.WinUI.TimerOverlayWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="FlyPPTTimer 计时窗口">
    <Grid x:Name="Root" Background="Transparent">
        <Border x:Name="TimerSurface" CornerRadius="6" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <TextBlock x:Name="TimerText" Text="{Binding TimerDisplay}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" />
        </Border>
    </Grid>
</Window>
