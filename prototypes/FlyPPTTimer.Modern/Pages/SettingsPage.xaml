<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="FlyPPTTimer_Modern.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:FlyPPTTimer_Modern.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="28,20" RowSpacing="16" MaxWidth="900" HorizontalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Spacing="4"><TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="设置"/><TextBlock Text="Fluent 设置窗口迁移原型" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/></StackPanel>
        <ScrollViewer Grid.Row="1">
            <StackPanel Spacing="12">
                <Border CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="18"><Grid ColumnSpacing="16"><Grid.ColumnDefinitions><ColumnDefinition Width="180"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><StackPanel><TextBlock FontWeight="SemiBold" Text="默认计时时长"/><TextBlock Text="没有文件规则时使用" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/></StackPanel><TextBox Grid.Column="1" Text="00:08:00"/></Grid></Border>
                <Border CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="18"><Grid ColumnSpacing="16"><Grid.ColumnDefinitions><ColumnDefinition Width="180"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><StackPanel><TextBlock FontWeight="SemiBold" Text="默认位置"/><TextBlock Text="多屏幕九宫格位置" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/></StackPanel><ComboBox Grid.Column="1" SelectedIndex="0"><ComboBoxItem Content="上中"/><ComboBoxItem Content="右上"/><ComboBoxItem Content="居中"/></ComboBox></Grid></Border>
                <Border CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="18"><Grid><TextBlock Text="暂停时闪烁当前时间" VerticalAlignment="Center"/><ToggleSwitch HorizontalAlignment="Right" OffContent="关闭" OnContent="开启"/></Grid></Border>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10"><Button Content="取消"/><Button Content="应用"/><Button Content="确定" Style="{StaticResource AccentButtonStyle}"/></StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
