<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="FlyPPTTimer_Modern.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:FlyPPTTimer_Modern.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="28,20" RowSpacing="16" MaxWidth="900" HorizontalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Spacing="4">
            <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="手机遥控" />
            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="二维码窗口 WinUI 3 原型，不接管现有远控服务。" />
        </StackPanel>
        <Grid Grid.Row="1" ColumnSpacing="16">
            <Grid.ColumnDefinitions><ColumnDefinition Width="280"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <Border CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="24">
                <Grid><FontIcon Glyph="&#xED14;" FontSize="96"/><TextBlock VerticalAlignment="Bottom" HorizontalAlignment="Center" Text="二维码由现有服务提供"/></Grid>
            </Border>
            <StackPanel Grid.Column="1" Spacing="12">
                <Border CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" Padding="18">
                    <Grid ColumnSpacing="12"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><StackPanel><TextBlock FontWeight="SemiBold" Text="服务已启动"/><TextBlock Text="端口在本次运行期间保持固定" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/></StackPanel><Button Grid.Column="1" Content="重启服务"/></Grid>
                </Border>
                <TextBlock Text="访问链接" FontWeight="SemiBold"/><TextBox Text="http://192.168.x.x:端口/?token=..." IsReadOnly="True"/>
                <Grid ColumnSpacing="10"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Button HorizontalAlignment="Stretch" Content="复制链接"/><Button Grid.Column="1" HorizontalAlignment="Stretch" Content="本机打开"/></Grid>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
